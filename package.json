{
  "name": "react-multiplayer",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "common",
    "preact-client",
    "backend",
    "database"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "client": "cd vite-client && npm run dev",
    "dev": "bun run --parallel client backend:dev",
    "dev:db": "cd db; docker-compose up -d",
    "backend:dev": "cd backend && bun run dev",
    "common:build": "cd common && bun run build",
    "common:dev": "cd common && bun run dev",
    "svelte:dev": "cd svelte-client && bun run dev",
    "svelte:build": "cd svelte-client && bun run build",
    "svelte:check": "cd svelte-client && bun run check",
    "preact:dev": "cd preact-client && bun run dev",
    "preact:build": "cd preact-client && bun run build",
    "test:countsets": "bun tests/test-countsets-efficiency.js",
    "predeploy": "cd preact-client && bun run build",
    "deploy": "gh-pages -d preact-client/dist -e client/",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/bun": "^1.3.6",
    "knex": "^3.2.10",
    "knex-bun-sqlite": "^1.4.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.8.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
